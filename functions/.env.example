# Copy to `.env` (never commit `.env`). Firebase CLI reads this when you deploy functions.
#
# Razorpay Dashboard → Settings → API Keys (use Test mode keys for dev, Live for production).
# Key ID and Key secret must be from the same mode and regenerated together if you rotate.
#
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
